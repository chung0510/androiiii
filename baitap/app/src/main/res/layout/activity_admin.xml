<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".AdminActivity">

    <!-- Header -->
    <View
        android:id="@+id/adminHeaderBg"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/glass_background"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvAdminTitle"
        style="@style/AppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ADMIN PANEL"
        android:layout_marginStart="24dp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvAdminSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quản lý hệ thống tủ"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvAdminTitle"
        app:layout_constraintStart_toStartOf="@id/tvAdminTitle" />

    <!-- Stats Section -->
    <LinearLayout
        android:id="@+id/layoutStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:layout_marginTop="-30dp"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/adminHeaderBg">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/glass_background">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TỔNG TỦ"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="42"
                    android:textColor="@color/neon_blue"
                    android:textSize="24sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/glass_background">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ĐANG THUÊ"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="18"
                    android:textColor="@color/neon_mint"
                    android:textSize="24sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- Menu Actions -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/layoutStats"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageLockers"
                style="@style/GlassButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:text="Quản lý danh sách tủ"
                android:gravity="start|center_vertical"
                android:paddingStart="24dp"
                app:icon="@drawable/ic_locker"
                app:iconTint="@color/neon_blue" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewOrders"
                style="@style/GlassButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:text="Lịch sử đơn hàng"
                android:gravity="start|center_vertical"
                android:paddingStart="24dp"
                app:icon="@drawable/ic_camera"
                app:iconTint="@color/neon_blue" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSystemSettings"
                style="@style/GlassButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:text="Cài đặt hệ thống"
                android:gravity="start|center_vertical"
                android:paddingStart="24dp"
                app:iconTint="@color/neon_blue" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdminLogout"
                style="@style/NeonButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"
                android:text="Đăng xuất Admin" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
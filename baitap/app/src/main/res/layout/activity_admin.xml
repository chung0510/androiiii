<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MAIN CONTENT -->

    <!-- DRAWER MENU -->

    <androidx.constraintlayout.widget.ConstraintLayout

        android:layout_width="match_parent"

        android:layout_height="match_parent"

        android:background="#F5F5F5">

        <!-- TOPBAR -->

        <include
            android:id="@+id/layoutTopBar"

            layout="@layout/layout_topbar"

            app:layout_constraintEnd_toEndOf="parent"

            app:layout_constraintStart_toStartOf="parent"

            app:layout_constraintTop_toTopOf="parent" />

        <!-- FRAGMENT CONTAINER -->

        <FrameLayout
            android:id="@+id/fragmentContainer"

            android:layout_width="0dp"

            android:layout_height="0dp"

            app:layout_constraintBottom_toBottomOf="parent"

            app:layout_constraintEnd_toEndOf="parent"

            app:layout_constraintStart_toStartOf="parent"

            app:layout_constraintTop_toBottomOf="@id/layoutTopBar" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:layout_width="320dp"

        android:layout_height="match_parent"

        android:layout_gravity="start"

        android:orientation="vertical"

        android:background="#FFFFFF">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"

            android:layout_height="270dp"

            android:orientation="vertical"

            android:padding="24dp"

            android:background="@drawable/bg_drawer_header">

            <!-- TOP -->

            <LinearLayout
                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"

                    android:layout_height="wrap_content"

                    android:layout_weight="1"

                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="Smart Locker Admin"

                        android:textColor="#FFFFFF"

                        android:textStyle="bold"

                        android:textSize="22sp"/>

                    <TextView
                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:layout_marginTop="6dp"

                        android:text="Hệ thống quản lý tủ thông minh"

                        android:textColor="#DDEEDD"

                        android:textSize="16sp"/>
                </LinearLayout>

                <!-- CLOSE -->

                <ImageButton
                    android:id="@+id/btnCloseDrawer"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_close_drawer"
                    android:padding="16dp"
                    android:src="@drawable/ic_close"
                    android:contentDescription="Close"/>
            </LinearLayout>

            <!-- PROFILE -->

            <LinearLayout
                android:layout_width="match_parent"

                android:layout_height="110dp"

                android:layout_marginTop="28dp"

                android:orientation="horizontal"

                android:gravity="center_vertical"

                android:padding="16dp"

                android:background="@drawable/bg_profile_drawer">

                <TextView
                    android:layout_width="60dp"

                    android:layout_height="60dp"

                    android:gravity="center"

                    android:text="AD"

                    android:textStyle="bold"

                    android:textSize="26sp"

                    android:textColor="#FFFFFF"

                    android:background="@drawable/bg_circle"/>

                <LinearLayout
                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"

                    android:layout_marginStart="18dp"

                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="Admin Hệ Thống"

                        android:textColor="#FFFFFF"

                        android:textStyle="bold"

                        android:textSize="20sp"/>

                    <TextView
                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:layout_marginTop="4dp"

                        android:text="Super Admin · Toàn quyền"

                        android:textColor="#DDEEDD"

                        android:textSize="16sp"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- MENU SCROLL -->

        <ScrollView
            android:layout_width="match_parent"

            android:layout_height="0dp"

            android:layout_weight="1"

            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/menuDashboard"

                    android:layout_width="match_parent"

                    android:layout_height="90dp"

                    android:layout_marginTop="12dp"

                    android:gravity="center_vertical"

                    android:paddingHorizontal="24dp"

                    android:background="#EEF5EF">

                    <TextView
                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="Dashboard"

                        android:textSize="20sp" />
                </LinearLayout>

                <!-- THÔNG BÁO -->

                <LinearLayout
                    android:id="@+id/menuNotification"

                    android:layout_width="match_parent"

                    android:layout_height="90dp"

                    android:gravity="center_vertical"

                    android:paddingHorizontal="24dp">

                    <TextView
                        android:layout_width="0dp"

                        android:layout_height="wrap_content"

                        android:layout_weight="1"

                        android:text="Thông báo"

                        android:textSize="20sp"

                        android:textColor="#424A5A"/>
                </LinearLayout>

                <!-- QUẢN LÝ TỦ -->

                <LinearLayout
                    android:id="@+id/menuLocker"

                    android:layout_width="match_parent"

                    android:layout_height="90dp"

                    android:gravity="center_vertical"

                    android:paddingHorizontal="24dp">

                    <TextView
                        android:layout_width="0dp"

                        android:layout_height="wrap_content"

                        android:layout_weight="1"

                        android:text="Quản lý tủ"

                        android:textSize="20sp"

                        android:textColor="#424A5A"/>
                </LinearLayout>

                <!-- SUB MENU -->
                <LinearLayout
                    android:id="@+id/layoutLockerSub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:orientation="vertical"
                    android:paddingStart="48dp"
                    android:paddingBottom="12dp"
                    android:background="#FFFFFF">
                    <!-- DANH SÁCH TỦ -->
                    <TextView
                        android:id="@+id/menuLockerList"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="• Danh sách tủ"
                        android:textSize="18sp"
                        android:textColor="#7A7F8B"/>
                    <!-- THÊM TỦ -->
                    <TextView
                        android:id="@+id/menuAddLocker"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:text="• Thêm tủ mới"
                        android:textSize="18sp"
                        android:textColor="#7A7F8B"/>
                </LinearLayout>

                <!-- ĐƠN THUÊ -->

                <LinearLayout
                    android:id="@+id/menuOrders"

                    android:layout_width="match_parent"

                    android:layout_height="90dp"

                    android:gravity="center_vertical"

                    android:paddingHorizontal="24dp">

                    <TextView
                        android:layout_width="0dp"

                        android:layout_height="wrap_content"

                        android:layout_weight="1"

                        android:text="Đơn thuê"

                        android:textSize="20sp"

                        android:textColor="#424A5A"/>
                </LinearLayout>

                <!-- Quản lý tài khoản -->

                <LinearLayout
                    android:id="@+id/menuAccount"

                    android:layout_width="match_parent"

                    android:layout_height="90dp"

                    android:gravity="center_vertical"

                    android:paddingHorizontal="24dp">

                    <TextView
                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="Quản lý tài khoản"

                        android:textSize="20sp"/>
                </LinearLayout>

                <!-- THIẾT LẬP GIÁ -->

                <LinearLayout
                    android:id="@+id/menuPrice"

                    android:layout_width="match_parent"

                    android:layout_height="90dp"

                    android:gravity="center_vertical"

                    android:paddingHorizontal="24dp">

                    <TextView
                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="Thiết lập giá"

                        android:textSize="20sp"

                        android:textColor="#424A5A"/>
                </LinearLayout>

                <!-- BÁO CÁO -->

                <LinearLayout
                    android:id="@+id/menuReport"

                    android:layout_width="match_parent"

                    android:layout_height="90dp"

                    android:gravity="center_vertical"

                    android:paddingHorizontal="24dp">

                    <TextView
                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="Báo cáo"

                        android:textSize="20sp"

                        android:textColor="#424A5A"/>
                </LinearLayout>

            </LinearLayout>

        </ScrollView>

        <!-- FIXED BOTTOM -->

        <LinearLayout
            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:orientation="vertical"

            android:paddingBottom="24dp"

            android:background="#FFFFFF">

            <View
                android:layout_width="match_parent"

                android:layout_height="1dp"

                android:background="#EEEEEE"/>
            <!-- LOGOUT -->

            <LinearLayout
                android:id="@+id/menuLogout"

                android:layout_width="match_parent"

                android:layout_height="90dp"

                android:gravity="center_vertical"

                android:paddingHorizontal="24dp">

                <FrameLayout
                    android:layout_width="50dp"

                    android:layout_height="50dp"

                    android:background="@drawable/bg_pink_box">

                    <ImageView
                        android:layout_width="24dp"

                        android:layout_height="24dp"

                        android:layout_gravity="center"

                        android:src="@drawable/ic_logout"

                        android:contentDescription="Logout"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"

                    android:layout_marginStart="20dp"

                    android:text="Đăng xuất"

                    android:textSize="20sp"

                    android:textColor="#C0392B"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>

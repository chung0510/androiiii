<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageView
            android:id="@+id/btnBack"
            android:src="@android:drawable/ic_media_previous"
            android:layout_width="30dp"
            android:layout_height="30dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THUÊ TỦ"
            android:textStyle="bold"
            android:textSize="28sp"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"/>

        <!-- TÊN -->
        <TextView
            android:text="Tên người thuê"
            android:textSize="16sp"
            android:layout_marginTop="30dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/edtName"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@color/gray_box"
            android:padding="12dp"
            android:textSize="16sp"/>

        <!-- SDT -->
        <TextView
            android:text="Số điện thoại"
            android:textSize="16sp"
            android:layout_marginTop="15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/edtPhone"
            android:inputType="phone"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@color/gray_box"
            android:padding="12dp"
            android:textSize="16sp"/>

        <!-- OPTION -->
        <TextView
            android:text="Chọn gói thuê"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="25dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerOption"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="10dp"/>

        <!-- OPTION ĐÃ CHỌN -->
        <TextView
            android:id="@+id/tvSelected"
            android:text="Chưa chọn gói"
            android:textColor="@color/green_main"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Ngăn còn trống"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:id="@+id/layoutSlots"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Thời lượng thuê"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Spinner
            android:id="@+id/spinnerDuration"
            android:layout_width="match_parent"
            android:layout_height="55dp"/>

        <TextView
            android:id="@+id/tvAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tổng tiền: 0 VNĐ"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/green_main"
            android:layout_marginTop="15dp"/>

        <!-- BUTTON -->
        <Button
            android:id="@+id/btnThue"
            android:text="THUÊ TỦ"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:backgroundTint="@color/green_main"
            android:layout_marginTop="30dp"
            android:layout_width="match_parent"
            android:layout_height="60dp"/>

        <!-- SUPPORT -->
        <TextView
            android:text="Nếu gặp vấn đề vui lòng liên hệ số điện thoại abcxyz để được hỗ trợ"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:textColor="#777777"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</ScrollView>